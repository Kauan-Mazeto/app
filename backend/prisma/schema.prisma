generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String
  crm           String?
  specialty     String?
  unit          String?
  healthUnitId  String?
  healthUnit    HealthUnit?    @relation(fields: [healthUnitId], references: [id])
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  appointments  Appointment[]
  prescriptions Prescription[]
  examsRequest  Exam[]         @relation("ExamRequestedBy")
  examsDeliver  Exam[]         @relation("ExamDeliveredBy")
  auditLogs     AuditLog[]
  stockTransactions StockTransaction[]
}

model Patient {
  id            String         @id @default(uuid())
  name          String
  cpf           String         @unique
  birthDate     String
  phone         String?
  address       String?
  lgpdAccepted  Boolean        @default(false)
  missedCount   Int            @default(0)
  blockedOnline Boolean        @default(false)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  appointments  Appointment[]
  prescriptions Prescription[]
  exams         Exam[]
  waitingList   WaitingList[]
  vacancies     Vacancy[]
}

model Appointment {
  id            String   @id @default(uuid())
  patientId     String
  doctorId      String
  specialty     String
  scheduledAt   DateTime
  priority      String   @default("normal")
  unit          String   @default("UBS Central")
  status        String   @default("aguardando")
  justification String?
  checkedIn     Boolean  @default(false)
  type          String   @default("presencial")
  createdAt     DateTime @default(now())
  patient       Patient  @relation(fields: [patientId], references: [id])
  doctor        User     @relation(fields: [doctorId], references: [id])
}

model OnlineSlotConfig {
  id               String   @id @default(uuid())
  unit             String
  dayOfWeek        Int // 0 = domingo ... 6 = sábado
  onlinePercentage Int      @default(50)
  maxOnlineSlots   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([unit, dayOfWeek])
}

model Prescription {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String
  doctorName      String
  doctorCrm       String?
  medication      String
  activeSubstance String
  dosage          String
  frequency       String
  durationDays    Int
  route           String   @default("Oral")
  schedule        String
  validationCode  String
  active          Boolean  @default(true)
  adherenceLogs   String   @default("[]")
  createdAt       DateTime @default(now())
  patient         Patient  @relation(fields: [patientId], references: [id])
  doctor          User     @relation(fields: [doctorId], references: [id])
}

model Exam {
  id               String    @id @default(uuid())
  patientId        String
  exam             String
  preparationNotes String?
  urgent           Boolean   @default(false)
  status           String    @default("pendente")
  lab_externo      String?
  requestedById    String
  deliveredById    String?
  deliveredAt      DateTime?
  createdAt        DateTime  @default(now())
  patient          Patient   @relation(fields: [patientId], references: [id])
  requestedBy      User      @relation("ExamRequestedBy", fields: [requestedById], references: [id])
  deliveredBy      User?     @relation("ExamDeliveredBy", fields: [deliveredById], references: [id])
}

model HealthUnit {
  id           String             @id @default(uuid())
  name         String
  users        User[]
  stocks       MedicineStock[]
  transactions StockTransaction[]
}

model MedicineStock {
  id           String     @id @default(uuid())
  healthUnitId String
  medicineId   String
  quantity     Int        @default(0)
  updatedAt    DateTime   @default(now()) @updatedAt
  healthUnit   HealthUnit @relation(fields: [healthUnitId], references: [id])

  @@unique([healthUnitId, medicineId])
}

model StockTransaction {
  id              String     @id @default(uuid())
  healthUnitId    String
  medicineId      String
  medicineName    String
  medicineDetails String?
  userId          String
  type            String
  quantity        Int
  createdAt       DateTime   @default(now())
  healthUnit      HealthUnit @relation(fields: [healthUnitId], references: [id])
  user            User       @relation(fields: [userId], references: [id])

  @@index([healthUnitId, medicineId])
  @@index([createdAt])
}

model WaitingList {
  id        String   @id @default(uuid())
  patientId String
  specialty String
  status    String   @default("waiting")
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Vacancy {
  id          String   @id @default(uuid())
  patientId   String
  patientName String
  specialty   String
  unit        String
  notifiedAt  DateTime
  deadline    DateTime
  status      String   @default("waiting_response")
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  userRole  String
  action    String
  target    String   @default("")
  details   String   @default("{}")
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AppointmentConfig {
  id             String   @id @default(uuid())
  specialty      String
  dayOfWeek      Int?
  specificDate   String?
  maxOnlineSlots Int      @default(10)
  maxTotalSlots  Int      @default(20)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String
}